# Database connection string
# For local development:
# DATABASE_URL=postgresql://username:password@localhost:5432/gedcom_viewer
# For Fly.io: This will be automatically set when you attach the database
DATABASE_URL=

# Session secret key - generate with: openssl rand -hex 32
SESSION_SECRET=

# Environment (development or production)
NODE_ENV=development

# Port (default: 3000)
PORT=3000
